# FolioChat server URL (used by the frontend widget)
FOLIOCHAT_URL=http://localhost:8000

# ── LLM API keys (set whichever LLM backend you use) ──────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Embedder API keys (only needed if not using the default local embedder) ───
VOYAGE_API_KEY=

# ── Optional: GitHub personal access token ────────────────────────────────────
# Raises the GitHub API rate limit from 60 to 5,000 requests/hour.
# Required when building the database for profiles with many repos.
GITHUB_TOKEN=ghp_...

# ── Optional: Ollama host (default: http://localhost:11434) ───────────────────
OLLAMA_HOST=http://localhost:11434

# ── Optional: CORS allowed origins for the FolioChat server ──────────────────
# Comma-separated list of origins. Defaults to * (all origins).
CORS_ORIGINS=https://yourportfolio.com
